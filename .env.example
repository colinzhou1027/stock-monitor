# ============================================
# 韩国游戏股票监控机器人 - 环境变量配置
# ============================================

# 【必填】企业微信群机器人 Webhook URL
# 获取方式：在企业微信群聊中添加群机器人，复制 Webhook 地址
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY_HERE

# 【可选】企业微信群机器人 Webhook URL（第二个群）
# 如果需要同时向多个群发送消息，配置此项
# WECOM_WEBHOOK_URL_2=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_SECOND_KEY_HERE

# ============================================
# AI 分析配置（可选）
# ============================================

# 【推荐】Google Gemini API Key
# 获取方式：访问 https://aistudio.google.com/apikey 登录 Google 账号获取
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Gemini 模型名称（可选）
# GEMINI_MODEL=gemini-2.5-flash

# 【备选】通义千问 API Key（阿里云百炼）
# 获取方式：访问 https://bailian.console.aliyun.com/ 创建 API Key
# QWEN_API_KEY=YOUR_QWEN_API_KEY

# 通义千问模型名称（可选）
# QWEN_MODEL=qwen-max

# ============================================
# 其他配置
# ============================================

# 涨跌幅阈值（百分比），超过此值将触发 @所有人
CHANGE_THRESHOLD=5.0

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
